{
  "name": "solana-new",
  "version": "0.1.0",
  "private": true,
  "description": "Discover the Solana ecosystem — repos, skills, and MCP servers",
  "type": "module",
  "bin": {
    "solana-new": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "skills/idea/",
    "skills/build/",
    "skills/launch/",
    "skills/data/",
    "skills/README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli/index.js",
    "dev": "tsx cli/index.ts",
    "postinstall": "node dist/cli/index.js init --agent 2>/dev/null || true"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsx": "^4.20.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "convex": "^1.34.1"
  }
}
